<style>
  .dash-greeting { margin-bottom: 28px; }
  .dash-greeting h2 { font-size: 1.6rem; font-weight: 800; color: #1a1a1a; margin-bottom: 4px; }
  .dash-greeting p  { font-size: 14px; color: #888; }

  .dash-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 18px; margin-bottom: 32px; }
  .dash-card {
    border-radius: 12px; padding: 22px 20px;
    display: flex; align-items: center; gap: 16px;
    color: #fff; position: relative; overflow: hidden;
  }
  .dash-card::after {
    content: ''; position: absolute; right: -20px; top: -20px;
    width: 90px; height: 90px;
    background: rgba(255,255,255,.1); border-radius: 50%;
  }
  .dash-card.green  { background: linear-gradient(135deg, #1a7a4a, #21a366); }
  .dash-card.blue   { background: linear-gradient(135deg, #1565c0, #1e88e5); }
  .dash-card.orange { background: linear-gradient(135deg, #e65100, #fb8c00); }
  .dash-card.purple { background: linear-gradient(135deg, #6a1b9a, #ab47bc); }
  .dash-card.teal   { background: linear-gradient(135deg, #00695c, #26a69a); }
  .dash-card-icon { font-size: 28px; opacity: .9; }
  .dash-card-info h4 { font-size: 13px; opacity: .85; margin: 0 0 4px; font-weight: 500; }
  .dash-card-info span { font-size: 26px; font-weight: 800; }

  .dash-shortcuts h5 { font-size: 15px; font-weight: 700; color: #333; margin-bottom: 16px; }
  .shortcuts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 14px; }
  .shortcut-btn {
    background: #f8f9fa; border: 1.5px solid #e8e8e8;
    border-radius: 10px; padding: 18px 14px;
    text-align: center; text-decoration: none;
    color: #333; font-size: 13px; font-weight: 600;
    transition: all .2s; display: flex; flex-direction: column;
    align-items: center; gap: 10px;
  }
  .shortcut-btn i { font-size: 22px; color: #1a7a4a; }
  .shortcut-btn:hover {
    background: #1a7a4a; color: #fff; border-color: #1a7a4a;
    transform: translateY(-3px); box-shadow: 0 6px 18px rgba(26,122,74,.25);
  }
  .shortcut-btn:hover i { color: #fff; }
</style>

<div class="dash-greeting">
