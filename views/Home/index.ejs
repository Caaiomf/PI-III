<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <title>Vitalis — Farmácia</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet"/>
  <link href="/css/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    :root {
      --vg: #1a7a4a;
      --vg-dark: #145e38;
      --vg-light: #21a366;
    }
    * { box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; background: #f4f6f8; }

    /* NAVBAR */
    .vitalis-nav {
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      padding: 0 40px;
      height: 62px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 1000;
      box-shadow: 0 2px 8px rgba(0,0,0,.07);
    }
    .vitalis-brand {
      display: flex;
      align-items: center;
      gap: 9px;
      font-size: 20px;
      font-weight: 800;
      color: var(--vg);
      text-decoration: none;
    }
    .brand-icon {
      background: var(--vg);
      color: #fff;
      width: 34px; height: 34px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; font-weight: 900;
    }
    .nav-links { display: flex; gap: 30px; list-style: none; margin: 0; padding: 0; }
    .nav-links a { color: #555; text-decoration: none; font-size: 14px; font-weight: 500; transition: color .2s; }
    .nav-links a:hover { color: var(--vg); }
    .nav-right { display: flex; align-items: center; gap: 12px; }
    .btn-cart {
      background: none; border: 1.5px solid #ddd; border-radius: 8px;
      padding: 7px 16px; cursor: pointer; font-size: 14px;
      display: flex; align-items: center; gap: 7px; transition: border-color .2s;
    }
    .btn-cart:hover { border-color: var(--vg); color: var(--vg); }
    .cart-badge {
      background: var(--vg); color: #fff; border-radius: 20px;
      padding: 1px 8px; font-size: 11px; font-weight: 700;
    }
    .btn-login {
      background: var(--vg); color: #fff; border: none; border-radius: 8px;
      padding: 8px 22px; font-size: 14px; font-weight: 600;
      cursor: pointer; text-decoration: none; transition: background .2s;
      display: flex; align-items: center; gap: 6px;
    }
    .btn-login:hover { background: var(--vg-dark); color: #fff; }

    /* HERO */
    .hero {
      background: linear-gradient(135deg, #1a7a4a 0%, #0b5394 100%);
      padding: 70px 60px 90px;
      color: #fff;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; right: 5%; top: -60px;
      width: 320px; height: 320px;
      background: rgba(255,255,255,.07); border-radius: 50%;
    }
    .hero::after {
      content: '';
      position: absolute; right: 15%; bottom: -80px;
      width: 200px; height: 200px;
      background: rgba(255,255,255,.05); border-radius: 50%;
    }
    .hero-badge {
      display: inline-block;
      background: rgba(255,255,255,.2);
      border-radius: 20px; padding: 4px 16px;
      font-size: 12px; font-weight: 600; letter-spacing: .6px; margin-bottom: 20px;
    }
    .hero h1 {
      font-size: 2.6rem; font-weight: 800; line-height: 1.2;
      margin: 0 0 16px; max-width: 540px;
    }
    .hero p {
      font-size: 14.5px; color: rgba(255,255,255,.82);
      max-width: 460px; margin: 0 0 30px; line-height: 1.7;
    }
    .hero-search {
      display: flex; max-width: 500px;
    }
    .hero-search input {
      flex: 1; padding: 13px 20px;
      border: none; border-radius: 8px 0 0 8px;
      font-size: 14px; outline: none;
    }
    .hero-search button {
      background: var(--vg-light); color: #fff;
      border: none; padding: 13px 24px;
      border-radius: 0 8px 8px 0;
      font-size: 14px; font-weight: 600; cursor: pointer; transition: background .2s;
    }
    .hero-search button:hover { background: var(--vg-dark); }

    /* PRODUCTS */
    .products-section { padding: 52px 60px; }
    .section-title { font-size: 1.35rem; font-weight: 700; color: #1a1a1a; margin-bottom: 4px; }
    .section-sub { font-size: 13px; color: #999; margin-bottom: 28px; }
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 22px;
    }
    .product-card {
      background: #fff; border-radius: 12px; overflow: hidden;
      box-shadow: 0 2px 10px rgba(0,0,0,.07);
      transition: transform .2s, box-shadow .2s;
      display: flex; flex-direction: column;
    }
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 28px rgba(0,0,0,.13); }
    .product-img {
      height: 155px; display: flex; align-items: center; justify-content: center;
      background: #f8f8f8; padding: 16px;
    }
    .product-img img { max-height: 125px; max-width: 100%; object-fit: contain; }
    .product-body { padding: 14px 16px; flex: 1; }
    .product-brand { font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 5px; }
    .product-name { font-size: 14px; font-weight: 700; color: #222; line-height: 1.3; margin-bottom: 8px; }
    .product-price { font-size: 17px; font-weight: 800; color: var(--vg); }
    .old-price { font-size: 12px; color: #999; text-decoration: line-through; margin-right: 6px; }
    .promo-badge { display:inline-block; margin-top:6px; background:#fff3cd; color:#8a5a00; border-radius:7px; padding:3px 7px; font-size:11px; font-weight:800; }
    .product-stock { font-size: 12px; color: #777; margin-top: 4px; }
    .product-stock.out { color: #c62828; font-weight: 700; }
    .product-footer { padding: 0 16px 16px; }
    .btn-add {
      width: 100%; background: none;
      border: 1.5px solid var(--vg); color: var(--vg);
      border-radius: 8px; padding: 9px;
      font-size: 13px; font-weight: 600; cursor: pointer; transition: all .2s;
    }
    .btn-add:hover { background: var(--vg); color: #fff; }

    /* FOOTER */
    footer {
      background: #12122a; color: rgba(255,255,255,.65);
      text-align: center; padding: 30px; font-size: 13px;
    }
    footer span { color: var(--vg-light); font-weight: 700; }

    @media (max-width: 768px) {
      .hero { padding: 40px 24px 60px; }
      .hero h1 { font-size: 1.85rem; }
      .products-section { padding: 32px 20px; }
      .vitalis-nav { padding: 0 16px; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="vitalis-nav">
    <a href="/" class="vitalis-brand">
      <div class="brand-icon">V</div>
      Vitalis
    </a>
    <ul class="nav-links">
      <li><a href="/"><i class="fas fa-store"></i> Loja</a></li>
      <li><a href="#produtos"><i class="fas fa-boxes"></i> Produtos</a></li>
      <li><a href="/agendamento"><i class="fas fa-calendar-check"></i> Agendamento</a></li>
    </ul>
    <div class="nav-right">
      <button class="btn-cart" data-bs-toggle="modal" data-bs-target="#modalCarrinho">
        <i class="fas fa-shopping-cart"></i>
        Carrinho
        <span class="cart-badge" id="contadorCarrinho">0</span>
      </button>
      <% if (clienteLogado) { %>
        <a href="/login" class="btn-login"><i class="fas fa-sign-out-alt"></i> Sair</a>
      <% } else { %>
        <a href="/login" class="btn-login"><i class="fas fa-user"></i> Entrar</a>
      <% } %>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge">Farmácia Vitalis</div>
    <h1>Cuidado, saúde e bem-estar em uma loja simples de usar.</h1>
    <p>Uma base de ecommerce para comprar produtos de farmácia, montar pedidos e separar o acesso de clientes e funcionários.</p>
    <div class="hero-search">
      <input type="text" id="inputBusca" placeholder="Busque por medicamento, higiene ou cuidados pessoais..." autocomplete="off">
      <button type="button" onclick="filtrarProdutos()"><i class="fas fa-search"></i> Buscar</button>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="products-section" id="produtos">
    <p class="section-title">Produtos em destaque</p>
    <p class="section-sub">Escolha os itens, adicione ao carrinho e confirme o pedido.</p>
    <div class="products-grid" id="productsGrid">
      <% produtos.map(function(value, index) { %>
        <div class="product-card"
             data-nome="<%= value.produtoNome.toLowerCase() %>"
             data-marca="<%= (value.marcaNome || '').toLowerCase() %>">
          <div class="product-img">
            <img src="<%= value.produtoImagem %>" alt="<%= value.produtoNome %>" />
          </div>
          <div class="product-body">
            <div class="product-brand"><%= value.marcaNome %></div>
            <div class="product-name"><%= value.produtoNome %></div>
            <% if (value.promocaoAtiva && value.valorPromocional) { %>
              <div class="product-price">
                <span class="old-price">R$ <%= parseFloat(value.produtoValor || 0).toFixed(2).replace('.', ',') %></span>
                R$ <%= parseFloat(value.valorPromocional || 0).toFixed(2).replace('.', ',') %>
              </div>
              <div class="promo-badge"><%= value.promocaoDescricao || 'Promoção' %></div>
            <% } else { %>
              <div class="product-price">R$ <%= parseFloat(value.produtoValor || 0).toFixed(2).replace('.', ',') %></div>
            <% } %>
            <% if (parseInt(value.produtoQuantidade || 0) > 0) { %>
              <div class="product-stock">Estoque: <%= value.produtoQuantidade %></div>
            <% } else { %>
              <div class="product-stock out">Sem estoque</div>
            <% } %>
          </div>
          <div class="product-footer">
            <% if (parseInt(value.produtoQuantidade || 0) > 0) { %>
              <button class="btn-add addCarrinho" data-produto="<%= value.produtoId %>">
                <i class="fas fa-cart-plus"></i> Adicionar ao carrinho
              </button>
            <% } else { %>
              <button class="btn-add" disabled style="opacity:.55;cursor:not-allowed;">
                <i class="fas fa-ban"></i> Indisponível
              </button>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    &copy; 2026 <span>Vitalis</span> — Farmácia Digital. Todos os direitos reservados.
  </footer>

  <!-- MODAL CARRINHO (Bootstrap 5) -->
  <div class="modal fade" id="modalCarrinho" tabindex="-1" aria-labelledby="modalCarrinhoLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalCarrinhoLabel">
            <i class="fas fa-shopping-cart me-2"></i> Carrinho de compras
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body" id="modalCarrinhoCorpo" style="min-height: 80px;">
          <p class="text-center text-muted">Carrinho vazio.</p>
        </div>
        <div class="modal-footer d-flex justify-content-between">
          <h5 class="mb-0" id="valorTotalPedido">Valor total: R$ 0,00</h5>
          <div>
            <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Fechar</button>
            <button id="btnConfirmar" type="button" class="btn btn-success">
              <i class="fas fa-check"></i> Confirmar Pedido
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/Ecommerce/ecommerce.js"></script>
  <script>
    function filtrarProdutos() {
      const termo = document.getElementById('inputBusca').value.toLowerCase().trim();
      document.querySelectorAll('.product-card').forEach(card => {
        const nome  = card.dataset.nome  || '';
        const marca = card.dataset.marca || '';
        card.style.display = (!termo || nome.includes(termo) || marca.includes(termo)) ? '' : 'none';
      });
    }
    document.getElementById('inputBusca').addEventListener('input', filtrarProdutos);
  </script>
</body>
</html>
