<script src="/js/servicos/listar.js"></script>
<style>
  .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; }
  .page-header h2 { font-size:1.4rem; font-weight:800; color:#1a1a1a; margin:0; }
  .btn-vitalis { background:#1a7a4a; color:#fff; border:none; border-radius:8px; padding:9px 20px; font-size:13px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:7px; transition:background .2s; }
  .btn-vitalis:hover { background:#145e38; color:#fff; }
  .vitalis-table { width:100%; border-collapse:collapse; }
  .vitalis-table th { padding:12px 16px; text-align:left; font-size:11px; font-weight:700; color:#999; text-transform:uppercase; letter-spacing:.6px; border-bottom:2px solid #f0f0f0; }
  .vitalis-table td { padding:13px 16px; font-size:14px; color:#333; border-bottom:1px solid #f5f5f5; vertical-align:middle; }
  .vitalis-table tbody tr:hover { background:#fafff9; }
  .badge-id     { background:#e8f5e9; color:#1a7a4a; border-radius:6px; padding:3px 10px; font-size:12px; font-weight:700; }
  .badge-ativo  { background:#e8f5e9; color:#2e7d32; border-radius:6px; padding:3px 10px; font-size:11px; font-weight:700; display:inline-flex; align-items:center; gap:5px; }
  .badge-inativo{ background:#fce4ec; color:#c62828; border-radius:6px; padding:3px 10px; font-size:11px; font-weight:700; display:inline-flex; align-items:center; gap:5px; }
  .price-tag    { font-size:15px; font-weight:800; color:#1a7a4a; }
  .btn-action   { border:none; border-radius:7px; padding:6px 12px; cursor:pointer; font-size:13px; display:inline-flex; align-items:center; gap:5px; text-decoration:none; transition:all .15s; }
  .btn-edit  { background:#e3f2fd; color:#1565c0; }
  .btn-edit:hover  { background:#1565c0; color:#fff; }
  .btn-del   { background:#fce4ec; color:#c62828; }
  .btn-del:hover   { background:#c62828; color:#fff; }
  .empty-state { text-align:center; padding:60px 20px; color:#bbb; }
  .empty-state i { font-size:48px; margin-bottom:16px; display:block; }
</style>

<div class="page-header">
  <h2><i class="fas fa-concierge-bell" style="color:#1a7a4a; margin-right:8px;"></i> Serviços</h2>
  <div style="display:flex; gap:10px; align-items:center;">
    <div style="display:flex; gap:8px; align-items:center;">
      <input id="f_q" placeholder="Buscar serviços..." style="padding:8px 10px; border-radius:8px; border:1px solid #ddd;" value="<%= (filtros && filtros.q) ? filtros.q : '' %>">
      <select id="f_status" style="padding:8px 10px; border-radius:8px; border:1px solid #ddd;">
        <option value="all">Todos</option>
        <option value="1" <%= (filtros && filtros.status=='1')?'selected':'' %>>Ativos</option>
        <option value="0" <%= (filtros && filtros.status=='0')?'selected':'' %>>Inativos</option>
      </select>
      <input id="f_min" type="number" step="0.01" placeholder="Min R$" style="width:110px;padding:8px 10px; border-radius:8px; border:1px solid #ddd;" value="<%= (filtros && filtros.minValor) ? filtros.minValor : '' %>">
      <input id="f_max" type="number" step="0.01" placeholder="Max R$" style="width:110px;padding:8px 10px; border-radius:8px; border:1px solid #ddd;" value="<%= (filtros && filtros.maxValor) ? filtros.maxValor : '' %>">
    </div>
    <a href="/servicos/cadastro" class="btn-vitalis"><i class="fas fa-plus"></i> Novo serviço</a>
  </div>
</div>

<% if (lista.length === 0) { %>
  <div class="empty-state">
    <i class="fas fa-concierge-bell"></i>
    <p>Nenhum serviço cadastrado ainda.</p>
    <a href="/servicos/cadastro" class="btn-vitalis">Cadastrar primeiro serviço</a>
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="vitalis-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Nome do serviço</th>
          <th>Valor</th>
          <th>Status</th>
          <th>Cadastrado em</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% lista.forEach(function(s) { %>
          <tr>
            <td><span class="badge-id"><%= s.id %></span></td>
            <td><strong><%= s.nome %></strong></td>
            <td><span class="price-tag">R$ <%= parseFloat(s.valor || 0).toFixed(2).replace('.', ',') %></span></td>
            <td>
              <% if (s.ativo == 1) { %>
                <span class="badge-ativo"><i class="fas fa-check-circle"></i> Ativo</span>
              <% } else { %>
                <span class="badge-inativo"><i class="fas fa-times-circle"></i> Inativo</span>
              <% } %>
            </td>
            <td style="color:#999; font-size:13px;">
              <%= s.criadoEm ? new Date(s.criadoEm).toLocaleDateString('pt-BR') : '—' %>
            </td>
            <td>
              <a href="/servicos/alterar/<%= s.id %>" class="btn-action btn-edit">
                <i class="fas fa-pen"></i> Editar
              </a>
              <button data-id="<%= s.id %>" class="btn-action btn-del btnExcluir">
                <i class="fas fa-trash"></i> Excluir
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
