<script src="/js/Produto/listar.js"></script>
<style>
  .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; }
  .page-header h2 { font-size:1.4rem; font-weight:800; color:#1a1a1a; margin:0; }
  .btn-vitalis {
    background:#1a7a4a; color:#fff; border:none; border-radius:8px;
    padding:9px 20px; font-size:13px; font-weight:600; cursor:pointer;
    text-decoration:none; display:inline-flex; align-items:center; gap:7px;
    transition:background .2s;
  }
  .btn-vitalis:hover { background:#145e38; color:#fff; }
  .vitalis-table { width:100%; border-collapse:collapse; }
  .vitalis-table th {
    padding:12px 16px; text-align:left; font-size:11px;
    font-weight:700; color:#999; text-transform:uppercase;
    letter-spacing:.6px; border-bottom:2px solid #f0f0f0;
  }
  .vitalis-table td { padding:12px 16px; font-size:14px; color:#333; border-bottom:1px solid #f5f5f5; vertical-align:middle; }
  .vitalis-table tbody tr:hover { background:#fafff9; }
  .badge-id { background:#e8f5e9; color:#1a7a4a; border-radius:6px; padding:3px 10px; font-size:12px; font-weight:700; }
  .badge-cat { background:#e3f2fd; color:#1565c0; border-radius:6px; padding:3px 10px; font-size:12px; font-weight:600; }
  .badge-marca { background:#fce4ec; color:#880e4f; border-radius:6px; padding:3px 10px; font-size:12px; font-weight:600; }
  .badge-qtd { background:#fff3e0; color:#e65100; border-radius:6px; padding:3px 10px; font-size:12px; font-weight:700; }
  .btn-action {
    border:none; border-radius:7px; padding:6px 12px; cursor:pointer; font-size:13px;
    display:inline-flex; align-items:center; gap:5px; text-decoration:none; transition:all .15s;
  }
  .btn-edit { background:#e3f2fd; color:#1565c0; }
  .btn-edit:hover { background:#1565c0; color:#fff; }
  .btn-del  { background:#fce4ec; color:#c62828; }
  .btn-del:hover { background:#c62828; color:#fff; }
  .product-thumb { width:56px; height:56px; object-fit:contain; border-radius:8px; background:#f5f5f5; padding:4px; }
</style>

<div class="page-header">
  <h2><i class="fas fa-pills me-2" style="color:#1a7a4a;"></i> Produtos</h2>
  <div style="display:flex; gap:10px; align-items:center;">
    <div style="display:flex; gap:8px; align-items:center;">
      <input id="f_q" placeholder="Buscar..." style="padding:8px 10px; border-radius:8px; border:1px solid #ddd;" value="<%= (filtros && filtros.q) ? filtros.q : '' %>">
      <select id="f_categoria" style="padding:8px 10px; border-radius:8px; border:1px solid #ddd;">
        <option value="0">Todas categorias</option>
        <% listaCategorias.forEach(function(c){ %>
          <option value="<%= c.categoriaId %>" <%= (filtros && filtros.categoria==c.categoriaId)?'selected':'' %>><%= c.categoriaNome %></option>
        <% }) %>
      </select>
      <select id="f_marca" style="padding:8px 10px; border-radius:8px; border:1px solid #ddd;">
        <option value="0">Todas marcas</option>
        <% listaMarcas.forEach(function(m){ %>
          <option value="<%= m.marcaId %>" <%= (filtros && filtros.marca==m.marcaId)?'selected':'' %>><%= m.marcaNome %></option>
        <% }) %>
      </select>
      <input id="f_min" type="number" step="0.01" placeholder="Min R$" style="width:110px;padding:8px 10px; border-radius:8px; border:1px solid #ddd;" value="<%= (filtros && filtros.minValor) ? filtros.minValor : '' %>">
      <input id="f_max" type="number" step="0.01" placeholder="Max R$" style="width:110px;padding:8px 10px; border-radius:8px; border:1px solid #ddd;" value="<%= (filtros && filtros.maxValor) ? filtros.maxValor : '' %>">
    </div>
    <a href="/produto/cadastro" class="btn-vitalis"><i class="fas fa-plus"></i> Cadastrar produto</a>
  </div>
</div>

<div class="table-responsive">
  <table class="vitalis-table">
    <thead>
      <tr>
        <th>Imagem</th>
        <th>Código</th>
        <th>Nome</th>
        <th>Qtd.</th>
        <th>Preço</th>
        <th>Categoria</th>
        <th>Marca</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% lista.map(function(value) { %>
        <tr>
          <td><img class="product-thumb" src="<%= value.produtoImagem %>" alt="<%= value.produtoNome %>"></td>
          <td><span class="badge-id"><%= value.produtoCodigo %></span></td>
          <td><strong><%= value.produtoNome %></strong></td>
          <td><span class="badge-qtd"><%= value.produtoQuantidade %></span></td>
          <td><strong style="color:#1a7a4a;">R$ <%= parseFloat(value.produtoValor || 0).toFixed(2).replace('.', ',') %></strong></td>
          <td><span class="badge-cat"><%= value.categoriaNome %></span></td>
          <td><span class="badge-marca"><%= value.marcaNome %></span></td>
          <td>
            <a href="/produto/alterar/<%= value.produtoId %>" class="btn-action btn-edit">
              <i class="fas fa-pen"></i> Editar
            </a>
            <button data-codigo="<%= value.produtoId %>" class="btn-action btn-del btnExcluir">
              <i class="fas fa-trash"></i> Excluir
            </button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
