<script src="/js/recebimentos/index.js"></script>
<style>
  .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
  .page-header h2 { font-size:1.4rem; font-weight:800; color:#1a1a1a; margin:0; }
  .panel-title { font-size:1rem; font-weight:800; color:#333; margin:0 0 14px; }
  .toolbar, .form-line { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
  .toolbar input, .form-line input, .form-line textarea { padding:9px 10px; border-radius:8px; border:1px solid #ddd; font-size:14px; }
  .form-line textarea { min-width:260px; min-height:38px; resize:vertical; }
  .btn-vitalis { background:#1a7a4a; color:#fff; border:none; border-radius:8px; padding:9px 18px; font-size:13px; font-weight:700; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:7px; }
  .btn-vitalis:hover { background:#145e38; color:#fff; }
  .btn-blue { background:#1565c0; }
  .vitalis-table { width:100%; border-collapse:collapse; }
  .vitalis-table th { padding:12px 16px; text-align:left; font-size:11px; font-weight:700; color:#999; text-transform:uppercase; letter-spacing:.6px; border-bottom:2px solid #f0f0f0; }
  .vitalis-table td { padding:12px 16px; font-size:14px; color:#333; border-bottom:1px solid #f5f5f5; }
  .vitalis-table input { padding:8px 10px; border-radius:8px; border:1px solid #ddd; width:100%; }
  .btn-rem { background:#fce4ec; color:#c62828; border:none; border-radius:7px; padding:6px 10px; cursor:pointer; }
</style>

<div class="page-header">
  <h2><i class="fas fa-hand-holding-usd me-2" style="color:#1a7a4a;"></i> Recebimentos</h2>
  <div class="toolbar">
    <input id="f_produto" placeholder="Produto ou ID">
    <input id="f_data_inicio" type="date">
    <input id="f_data_fim" type="date">
    <button id="btnFiltrarRecebimentos" class="btn-vitalis"><i class="fas fa-search"></i> Filtrar</button>
    <a href="/admin" class="btn-vitalis"><i class="fas fa-home"></i> Painel</a>
  </div>
</div>

<h3 class="panel-title">Novo recebimento</h3>
<div class="form-line" style="margin-bottom:10px;">
  <input id="recebimentoFuncionario" type="number" min="1" value="1" placeholder="Funcionário ID">
  <input id="recebimentoData" type="date">
  <textarea id="recebimentoObservacao" placeholder="Observação"></textarea>
  <button id="btnAddRecebimentoItem" class="btn-vitalis btn-blue" type="button"><i class="fas fa-plus"></i> Item</button>
</div>
<div class="table-responsive">
  <table class="vitalis-table" id="tbItensRecebimento">
    <thead><tr><th>Produto ID</th><th>Quantidade</th><th>Valor unitário</th><th>Validade</th><th></th></tr></thead>
    <tbody></tbody>
  </table>
</div>
<div style="margin-top:12px; text-align:right;">
  <button id="btnSalvarRecebimento" class="btn-vitalis"><i class="fas fa-save"></i> Salvar recebimento</button>
</div>

<hr style="margin:28px 0;">
<h3 class="panel-title">Recebimentos registrados</h3>
<div class="table-responsive">
  <table class="vitalis-table" id="tbRecebimentos">
    <thead><tr><th>ID</th><th>Produto</th><th>Qtd.</th><th>Valor unit.</th><th>Validade</th><th>Data</th><th>Observação</th></tr></thead>
    <tbody></tbody>
  </table>
</div>
