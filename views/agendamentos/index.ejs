<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Vitalis - Agendamento</title>
  <link href="/css/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { font-family:'Segoe UI', Arial, sans-serif; background:#f4f6f8; margin:0; }
    .topbar { background:#fff; border-bottom:1px solid #e5e5e5; height:62px; display:flex; align-items:center; justify-content:space-between; padding:0 40px; }
    .brand { color:#1a7a4a; font-weight:800; font-size:20px; text-decoration:none; display:flex; align-items:center; gap:9px; }
    .brand-icon { background:#1a7a4a; color:#fff; width:34px; height:34px; border-radius:8px; display:flex; align-items:center; justify-content:center; }
    .btn-vitalis { background:#1a7a4a; color:#fff; border:none; border-radius:8px; padding:10px 18px; font-weight:700; text-decoration:none; display:inline-flex; gap:7px; align-items:center; }
    .btn-vitalis:hover { background:#145e38; color:#fff; }
    .wrap { max-width:1120px; margin:34px auto; padding:0 18px; }
    .grid { display:grid; grid-template-columns:minmax(320px, 420px) 1fr; gap:22px; align-items:start; }
    .panel { background:#fff; border-radius:8px; border:1px solid #e9e9e9; padding:22px; }
    .panel h2 { font-size:1.25rem; font-weight:800; margin:0 0 16px; color:#1a1a1a; }
    .form-field { display:flex; flex-direction:column; gap:6px; margin-bottom:13px; }
    .form-field label { font-size:12px; font-weight:800; color:#666; text-transform:uppercase; }
    .form-field input, .form-field select, .form-field textarea { border:1px solid #ddd; border-radius:8px; padding:10px 12px; font-size:14px; }
    .form-field textarea { min-height:80px; resize:vertical; }
    .vitalis-table { width:100%; border-collapse:collapse; }
    .vitalis-table th { padding:11px 12px; font-size:11px; color:#888; text-transform:uppercase; border-bottom:2px solid #f0f0f0; text-align:left; }
    .vitalis-table td { padding:12px; border-bottom:1px solid #f5f5f5; font-size:14px; }
    .notice { border-radius:8px; padding:10px 12px; background:#f7faf8; border:1px solid #dfeee5; color:#1a7a4a; font-weight:700; margin-bottom:14px; }
    @media (max-width:900px) { .topbar { padding:0 18px; } .grid { grid-template-columns:1fr; } }
  </style>
</head>
<body>
  <nav class="topbar">
    <a href="/" class="brand"><span class="brand-icon">V</span> Vitalis</a>
    <div style="display:flex; gap:10px;">
      <a href="/" class="btn-vitalis"><i class="fas fa-store"></i> Loja</a>
      <a href="/login" class="btn-vitalis"><i class="fas fa-sign-out-alt"></i> Sair</a>
    </div>
  </nav>

  <main class="wrap">
    <% if (mensagem) { %><div class="notice"><%= mensagem %></div><% } %>
    <div class="grid">
      <section class="panel">
        <h2><i class="fas fa-calendar-check" style="color:#1a7a4a;"></i> Novo agendamento</h2>
        <div class="form-field">
          <label for="servicoId">Serviço</label>
          <select id="servicoId">
            <option value="">Selecione</option>
            <% (servicos || []).forEach(function(s) { %>
              <option value="<%= s.id %>"><%= s.nome %> - R$ <%= parseFloat(s.valor || 0).toFixed(2).replace('.', ',') %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-field">
          <label for="profissionalId">Profissional</label>
          <select id="profissionalId">
            <option value="">Selecione</option>
            <% (profissionais || []).forEach(function(p) { %>
              <option value="<%= p.usuarioId %>"><%= p.usuarioNome %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-field">
          <label for="data">Dia</label>
          <input id="data" type="date">
        </div>
        <div class="form-field">
          <label for="hora">Hora</label>
          <input id="hora" type="time" min="06:00" max="19:00" step="1800">
        </div>
        <div class="form-field">
          <label for="observacao">Observação</label>
          <textarea id="observacao"></textarea>
        </div>
        <button class="btn-vitalis" id="btnAgendar" style="width:100%;justify-content:center;"><i class="fas fa-check"></i> Solicitar agendamento</button>
      </section>

      <section class="panel">
        <h2><i class="fas fa-list" style="color:#1a7a4a;"></i> Meus agendamentos</h2>
        <div class="table-responsive">
          <table class="vitalis-table">
            <thead><tr><th>Serviço</th><th>Profissional</th><th>Data</th><th>Status</th></tr></thead>
            <tbody>
              <% if (!agendamentos || agendamentos.length === 0) { %>
                <tr><td colspan="4" style="text-align:center;color:#999;">Nenhum agendamento registrado.</td></tr>
              <% } %>
              <% (agendamentos || []).forEach(function(a) { %>
                <tr>
                  <td><%= a.stp_nome %></td>
                  <td><%= a.profissional %></td>
                  <td><%= new Date(a.age_data).toLocaleDateString('pt-BR') %> às <%= String(a.age_hora).slice(0,5) %></td>
                  <td><%= a.age_status %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>

  <script>
    const campoData = document.getElementById('data');
    const campoHora = document.getElementById('hora');

    function hojeISO() {
      const hoje = new Date();
      const ano = hoje.getFullYear();
      const mes = String(hoje.getMonth() + 1).padStart(2, '0');
      const dia = String(hoje.getDate()).padStart(2, '0');
      return `${ano}-${mes}-${dia}`;
    }

    function dataValida(data) {
      if(!data) return false;
      const escolhido = new Date(data + 'T00:00:00');
      const hoje = new Date(hojeISO() + 'T00:00:00');
      return escolhido.getTime() >= hoje.getTime() && escolhido.getDay() !== 0;
    }

    function horaValida(hora) {
      if(!hora) return false;
      const partes = hora.split(':');
      const minutos = (parseInt(partes[0]) * 60) + parseInt(partes[1] || '0');
      return minutos >= 360 && minutos <= 1140;
    }

    campoData.min = hojeISO();
    campoData.addEventListener('change', function() {
      if(this.value && !dataValida(this.value)) {
        alert('Escolha uma data a partir de hoje, de segunda a sábado.');
        this.value = '';
      }
    });

    campoHora.addEventListener('change', function() {
      if(this.value && !horaValida(this.value)) {
        alert('Escolha um horário entre 06:00 e 19:00.');
        this.value = '';
      }
    });

    document.getElementById('btnAgendar').addEventListener('click', function() {
      const servicoId = document.getElementById('servicoId').value;
      const profissionalId = document.getElementById('profissionalId').value;
      const data = document.getElementById('data').value;
      const hora = document.getElementById('hora').value;
      const observacao = document.getElementById('observacao').value;

      if(!servicoId || !profissionalId || !data || !hora) {
        alert('Informe serviço, profissional, data e hora.');
        return;
      }

      if(!dataValida(data)) {
        alert('Escolha uma data a partir de hoje, de segunda a sábado.');
        return;
      }

      if(!horaValida(hora)) {
        alert('Escolha um horário entre 06:00 e 19:00.');
        return;
      }

      fetch('/agendamento/cadastrar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ servicoId, profissionalId, data, hora, observacao })
      })
      .then(r => r.json())
      .then(r => {
        alert(r.msg || 'Agendamento atualizado.');
        if(r.precisaLogin) window.location.href = '/login';
        if(r.ok) window.location.reload();
      })
      .catch(() => alert('Erro ao solicitar agendamento.'));
    });
  </script>
</body>
</html>
