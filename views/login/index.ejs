<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Vitalis - Entrar</title>
  <link rel="stylesheet" href="/css/fontawesome-free/css/all.min.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, #1a7a4a 0%, #0b5394 100%);
      display: flex; align-items: center; justify-content: center;
      padding: 22px;
    }
    .login-wrapper {
      display: grid; grid-template-columns: 1fr 430px;
      width: 940px; max-width: 98vw;
      border-radius: 18px; overflow: hidden;
      box-shadow: 0 24px 64px rgba(0,0,0,.3);
      background: #fff;
    }
    .login-left {
      background: linear-gradient(160deg, #145e38 0%, #0b5394 100%);
      color: #fff; padding: 56px 44px;
      display: flex; flex-direction: column; justify-content: center;
    }
    .login-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 40px; }
    .login-logo .icon {
      background: rgba(255,255,255,.2);
      width: 40px; height: 40px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; font-weight: 900;
    }
    .login-logo span { font-size: 22px; font-weight: 800; }
    .login-left h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 14px; line-height: 1.3; }
    .login-left p { font-size: 14px; color: rgba(255,255,255,.78); line-height: 1.7; margin-bottom: 32px; }
    .feature { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; font-size: 14px; }
    .feature i { width: 28px; text-align: center; font-size: 15px; color: rgba(255,255,255,.75); }
    .login-right { padding: 42px 38px; display: flex; flex-direction: column; justify-content: center; }
    .login-right h3 { font-size: 1.35rem; font-weight: 800; color: #1a1a1a; margin-bottom: 6px; }
    .login-right .sub { font-size: 13px; color: #888; margin-bottom: 20px; }
    .tabs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-bottom: 24px; }
    .tab {
      text-align: center; padding: 10px 8px; border-radius: 8px;
      background: #f1f3f5; color: #555; text-decoration: none;
      font-size: 12px; font-weight: 800;
    }
    .tab.active { background: #1a7a4a; color: #fff; }
    .form-panel { display: none; }
    .form-panel.active { display: block; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; font-weight: 700; color: #444; margin-bottom: 7px; }
    .input-wrap {
      display: flex; align-items: center;
      border: 1.5px solid #ddd; border-radius: 9px; overflow: hidden;
      transition: border-color .2s;
    }
    .input-wrap:focus-within { border-color: #1a7a4a; }
    .input-wrap i { padding: 0 14px; color: #aaa; font-size: 15px; }
    .input-wrap input {
      flex: 1; border: none; outline: none;
      padding: 12px 12px 12px 0;
      font-size: 14px; background: transparent;
    }
    .btn-submit {
      width: 100%; background: #1a7a4a; color: #fff;
      border: none; border-radius: 9px; padding: 13px;
      font-size: 15px; font-weight: 800; cursor: pointer;
      transition: background .2s; margin-top: 4px;
    }
    .btn-submit:hover { background: #145e38; }
    .hint { font-size: 12px; color: #888; line-height: 1.5; margin: -6px 0 14px; }
    .error-msg {
      background: #fff3f3; border: 1px solid #f5c6c6;
      color: #c0392b; border-radius: 8px;
      padding: 10px 14px; font-size: 13px; margin-bottom: 16px;
      display: flex; align-items: center; gap: 8px;
    }
    .back-link {
      display: block; text-align: center; margin-top: 22px;
      font-size: 13px; color: #777; text-decoration: none;
    }
    .back-link:hover { color: #1a7a4a; }
    @media (max-width: 760px) {
      .login-wrapper { grid-template-columns: 1fr; }
      .login-left { display: none; }
      .login-right { padding: 34px 24px; }
    }
  </style>
</head>
<body>
  <% const aba = typeof tipo != 'undefined' ? tipo : 'cliente'; %>
  <div class="login-wrapper">
    <div class="login-left">
      <div class="login-logo">
        <div class="icon">V</div>
        <span>Vitalis</span>
      </div>
      <h2>Escolha seu acesso Vitalis</h2>
      <p>Clientes compram pela loja. Funcionários acessam o painel administrativo com e-mail corporativo.</p>
      <div class="feature"><i class="fas fa-shopping-cart"></i> Compra online para clientes cadastrados</div>
      <div class="feature"><i class="fas fa-user-shield"></i> Painel separado para funcionários</div>
      <div class="feature"><i class="fas fa-lock"></i> Validação de e-mail único no cadastro</div>
    </div>

    <div class="login-right">
      <h3>Entrar na Vitalis</h3>
      <p class="sub">Selecione o tipo de acesso para continuar.</p>

      <div class="tabs">
        <a href="#" class="tab <%= aba === 'cliente' ? 'active' : '' %>" data-tab="cliente">Cliente</a>
        <a href="#" class="tab <%= aba === 'funcionario' ? 'active' : '' %>" data-tab="funcionario">Funcionário</a>
        <a href="#" class="tab <%= aba === 'cadastro' ? 'active' : '' %>" data-tab="cadastro">Cadastro</a>
      </div>

      <% if (typeof msg != 'undefined' && msg) { %>
        <div class="error-msg"><i class="fas fa-exclamation-circle"></i> <%= msg %></div>
      <% } %>

      <form class="form-panel <%= aba === 'cliente' ? 'active' : '' %>" id="panel-cliente" action="/login/cliente" method="post">
        <div class="form-group">
          <label for="clienteEmail">E-mail do cliente</label>
          <div class="input-wrap"><i class="fas fa-envelope"></i><input type="email" id="clienteEmail" name="email" placeholder="seu@email.com" required></div>
        </div>
        <div class="form-group">
          <label for="clienteSenha">Senha</label>
          <div class="input-wrap"><i class="fas fa-lock"></i><input type="password" id="clienteSenha" name="password" placeholder="Sua senha" required></div>
        </div>
        <button type="submit" class="btn-submit"><i class="fas fa-sign-in-alt"></i> Entrar como cliente</button>
      </form>

      <form class="form-panel <%= aba === 'funcionario' ? 'active' : '' %>" id="panel-funcionario" action="/login/funcionario" method="post">
        <p class="hint">Use obrigatoriamente seu e-mail corporativo terminado em <strong>@vitalis.com</strong>.</p>
        <div class="form-group">
          <label for="funcEmail">E-mail do funcionário</label>
          <div class="input-wrap"><i class="fas fa-briefcase"></i><input type="email" id="funcEmail" name="email" placeholder="nome@vitalis.com" required></div>
        </div>
        <div class="form-group">
          <label for="funcSenha">Senha</label>
          <div class="input-wrap"><i class="fas fa-lock"></i><input type="password" id="funcSenha" name="password" placeholder="Sua senha" required></div>
        </div>
        <button type="submit" class="btn-submit"><i class="fas fa-user-shield"></i> Entrar no painel</button>
      </form>

      <form class="form-panel <%= aba === 'cadastro' ? 'active' : '' %>" id="panel-cadastro" action="/login/cadastro-cliente" method="post">
        <div class="form-group">
          <label for="cadNome">Nome completo</label>
          <div class="input-wrap"><i class="fas fa-user"></i><input type="text" id="cadNome" name="nome" placeholder="Seu nome" required></div>
        </div>
        <div class="form-group">
          <label for="cadEmail">E-mail</label>
          <div class="input-wrap"><i class="fas fa-envelope"></i><input type="email" id="cadEmail" name="email" placeholder="seu@email.com" required></div>
        </div>
        <div class="form-group">
          <label for="cadSenha">Senha</label>
          <div class="input-wrap"><i class="fas fa-lock"></i><input type="password" id="cadSenha" name="senha" placeholder="Crie uma senha" required></div>
        </div>
        <div class="form-group">
          <label for="cadCpf">CPF</label>
          <div class="input-wrap"><i class="fas fa-id-card"></i><input type="text" id="cadCpf" name="cpf" maxlength="14" placeholder="000.000.000-00"></div>
        </div>
        <div class="form-group">
          <label for="cadTelefone">Telefone</label>
          <div class="input-wrap"><i class="fas fa-phone"></i><input type="text" id="cadTelefone" name="telefone" placeholder="(00) 00000-0000"></div>
        </div>
        <div class="form-group">
          <label for="cadNascimento">Data de nascimento</label>
          <div class="input-wrap"><i class="fas fa-calendar"></i><input type="date" id="cadNascimento" name="dataNascimento"></div>
        </div>
        <button type="submit" class="btn-submit"><i class="fas fa-user-plus"></i> Criar conta</button>
      </form>

      <a href="/" class="back-link"><i class="fas fa-arrow-left"></i> Voltar à loja</a>
    </div>
  </div>

  <script>
    document.querySelectorAll('.tab').forEach(function(tab) {
      tab.addEventListener('click', function(e) {
        e.preventDefault();
        document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
        document.querySelectorAll('.form-panel').forEach(function(p) { p.classList.remove('active'); });
        tab.classList.add('active');
        document.getElementById('panel-' + tab.dataset.tab).classList.add('active');
      });
    });

    const nascimento = document.getElementById('cadNascimento');
    if(nascimento) {
      const hoje = new Date();
      hoje.setMinutes(hoje.getMinutes() - hoje.getTimezoneOffset());
      nascimento.max = hoje.toISOString().slice(0, 10);
    }
  </script>
</body>
</html>
